    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="esgotado, n" type="String" array="False" size=""/>
            <output expression="&quot;O produto esta esgotado? (s/n)&quot;" newline="True"/>
            <input variable="esgotado"/>
            <if expression="esgotado = &quot;n&quot;">
                <then>
                    <output expression="&quot;Produto disponivel para venda&quot;" newline="True"/>
                </then>
                <else>
                    <output expression="&quot;Por favor, restabele&#231;a o estoque&quot;" newline="True"/>
                </else>
            </if>
        </body>
    </function>
</flowgorithm>
