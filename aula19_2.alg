algoritmo "aula19_2"
// F9 (executa seu código)

// Autor : Danielli
// Data : 14/04/2026

var
// Variaveis
   idade: real
   gratuito, pago: literal
   
inicio
// Comandos
   escreva ("Informe sua idade: ")
   leia (idade)
   se (idade < 5) ou (idade >=65) entao
   escreval ("Entrada gratuita!")
   senao
   escreval ("Entrada paga...")
   fimse

fimalgoritmo
